<!DOCTYPE html>
<html>
<head>
    <title>SentinelSOC Pro</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body data-theme="{{ settings.theme }}">

<div id="intro">
    <div class="logo-box">
        <div class="shield-logo">
            <svg viewBox="0 0 200 220" class="shield-svg" xmlns="http://www.w3.org/2000/svg">
                <path d="M100 10 L170 40 L170 105 C170 155, 140 190, 100 210 C60 190, 30 155, 30 105 L30 40 Z" class="shield-shape"/>
                <path d="M45 112 L68 112 L80 92 L94 136 L108 78 L122 112 L155 112" class="ecg-line"/>
            </svg>
        </div>
        <h1>SentinelSOC Pro</h1>
        <p>Built by Nowfir</p>
        <div class="loading-bar"><div class="loading-fill"></div></div>
    </div>
</div>

<div id="dashboard-content" class="hidden">
    <div class="sidebar">
        <h2>SentinelSOC Pro</h2>
        <p class="credit">Built by Nowfir</p>
        <ul>
            <li><a href="/">Dashboard</a></li>
            <li><a href="/alerts">Alerts</a></li>
            <li><a href="/incidents">Incidents</a></li>
            <li><a href="/threat">Threat Intel</a></li>
            <li><a href="/reports">Reports</a></li>
            <li><a href="/settings">Settings</a></li>
        </ul>
    </div>

    <div class="main">
        <h1>SOC Dashboard</h1>
        <p class="subtitle">
            Auto Refresh: <span id="refresh-status">{{ "ON" if settings.auto_refresh_enabled else "OFF" }}</span> |
            Last Scan: <span id="last-scan">{{ last_scan }}</span>
        </p>

        <div class="cards">
            <div class="card">
                <h3>Total Alerts</h3>
                <p id="total-alerts">{{ total_alerts }}</p>
            </div>
            <div class="card">
                <h3>Critical Alerts</h3>
                <p id="critical-count">{{ critical_count }}</p>
            </div>
            <div class="card">
                <h3>Open Incidents</h3>
                <p id="incident-count">{{ incident_count }}</p>
            </div>
            <div class="card">
                <h3>Top Attacker IP</h3>
                <p id="top-attacker" style="font-size:18px">{{ top_attacker }}</p>
            </div>
        </div>

        <div class="card" style="margin-top:30px;">
            <h3>Global Attack Map</h3>
            <div id="attack-map"></div>
        </div>

        <div class="card" style="margin-top:30px;">
            <h3>SOC Attack Timeline</h3>
            <canvas id="timelineChart"></canvas>
        </div>

        <div class="card" style="margin-top:30px;">
            <h3>Alert Severity Chart</h3>
            <canvas id="severityChart"></canvas>
        </div>
    </div>
</div>

<script>
window.SENTINEL_SETTINGS = {
    auto_refresh_enabled: {{ "true" if settings.auto_refresh_enabled else "false" }},
    refresh_seconds: {{ settings.refresh_seconds }},
    theme: "{{ settings.theme }}",
    siren_enabled: {{ "true" if settings.siren_enabled else "false" }},
    siren_seconds: {{ settings.siren_seconds }},
    custom_siren_file: "{{ settings.custom_siren_file }}"
};

window.SENTINEL_INITIAL = {
    critical_count: {{ critical_count }},
    high_count: {{ high_count }},
    medium_count: {{ medium_count }}
};
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const intro = document.getElementById("intro");
    const content = document.getElementById("dashboard-content");
    const seen = sessionStorage.getItem("sentinelsoc_intro_seen");

    if (seen === "yes") {
        intro.style.display = "none";
        content.classList.remove("hidden");
        document.body.style.overflow = "auto";
    } else {
        setTimeout(function () {
            intro.style.display = "none";
            content.classList.remove("hidden");
            content.classList.add("fade-in");
            document.body.style.overflow = "auto";
            sessionStorage.setItem("sentinelsoc_intro_seen", "yes");
        }, 2500);
    }
});
</script>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="{{ url_for('static', filename='app.js') }}"></script>

</body>
</html>
